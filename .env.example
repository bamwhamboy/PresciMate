# Copy this to .env and fill in your keys
ANTHROPIC_API_KEY=sk-ant-...
SARVAM_API_KEY=sk_...

# Optional: set OCR_PROVIDER and/or CHAT_PROVIDER to "gemini" to use
# Google's free-tier model instead of Claude. Read the privacy note in
# README.md first - free-tier Gemini traffic can be reviewed by Google,
# which matters for real medical images/text.
OCR_PROVIDER=claude
CHAT_PROVIDER=claude
GEMINI_API_KEY=

# Optional overrides (defaults shown)
OCR_MODEL=claude-sonnet-5
GEMINI_MODEL=gemini-2.5-flash
CHAT_MODEL=claude-sonnet-5
QDRANT_PATH=./qdrant_data
DRUG_COLLECTION=drug_knowledge
USER_COLLECTION=user_prescriptions
DB_PATH=prescribot.db
DENSE_MODEL=BAAI/bge-small-en-v1.5
USERS_FILE=users.yaml
