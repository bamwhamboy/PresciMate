# Streamlit secrets template.
#
# LOCAL USE: copy this file to .streamlit/secrets.toml (same folder name,
# just remove ".example") and fill in real values. That file is
# gitignored - never commit it.
#
# STREAMLIT COMMUNITY CLOUD: don't upload this file at all. Instead, paste
# its contents (with real values) into your app's Settings -> Secrets box
# in the Streamlit Cloud dashboard. Cloud deployments don't read .env
# files, only st.secrets - which is exactly why config.py's _get_secret()
# checks st.secrets first and falls back to .env for local runs.

ANTHROPIC_API_KEY = "sk-ant-..."
SARVAM_API_KEY = "sk_..."
GEMINI_API_KEY = ""

# "claude" or "gemini" for each - see README's provider comparison table
OCR_PROVIDER = "claude"
CHAT_PROVIDER = "claude"

# Optional overrides (defaults shown - only needed if you want to change them)
OCR_MODEL = "claude-sonnet-5"
GEMINI_MODEL = "gemini-3.1-flash-lite"
CHAT_MODEL = "claude-sonnet-5"
